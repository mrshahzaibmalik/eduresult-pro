# ─────────────────────────────────────────────
# EduResult Pro — Environment Variables
# Copy this to .env and edit values
# ─────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Environment: development | production
NODE_ENV=development

# CHANGE THIS in production! Use a long random string.
JWT_SECRET=eduresult_super_secret_jwt_2024_CHANGE_ME_NOW

# SQLite database file path
DB_PATH=./data/eduresult.db

# CORS: comma-separated allowed origins, or * for all
# Example production: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*
